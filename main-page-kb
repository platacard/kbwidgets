<style>
  .kb-wrap{
    font-family:'Poppins', Arial, sans-serif;
    background:#fff2e6;
    border:2px solid #ff7a00;
    border-radius:14px;
    padding:16px;
    color:#000;
    box-sizing:border-box;
    width:100%;
  }

  .kb-title{
    background:#ff7a00;
    color:#fff;
    text-align:center;
    font-size:20px;
    font-weight:700;
    padding:14px;
    border-radius:10px;
    margin-bottom:14px;
  }

  .kb-section-title{
    background:#ff7a00;
    color:#fff;
    font-weight:700;
    text-align:center;
    padding:10px 12px;
    border-radius:10px;
    margin:16px 0 10px;
    font-size:17px;
  }

  .kb-instruction{
    background:#fffaf5;
    border:1px solid rgba(255,122,0,0.45);
    border-radius:10px;
    padding:12px;
    text-align:center;
    margin-bottom:12px;
    line-height:1.45;
  }

  .kb-search{
    width:100%;
    padding:12px 14px;
    border:2px solid #ff7a00;
    border-radius:10px;
    font-family:'Poppins', Arial, sans-serif;
    font-size:16px;
    box-sizing:border-box;
    margin-bottom:14px;
    background:#fff;
  }

  .kb-filters{
    display:flex;
    flex-wrap:wrap;
    gap:8px;
    justify-content:center;
    margin-bottom:16px;
  }

  .kb-filter{
    border:2px solid #ff7a00;
    background:#fffaf5;
    color:#000;
    border-radius:999px;
    padding:8px 12px;
    font-family:'Poppins', Arial, sans-serif;
    font-size:14px;
    font-weight:600;
    cursor:pointer;
  }

  .kb-filter.active,
  .kb-filter:hover{
    background:#ff7a00;
    color:#fff;
  }

  .kb-grid{
    display:grid;
    grid-template-columns:repeat(auto-fit, minmax(280px, 1fr));
    gap:14px;
  }

  .kb-card{
    background:#fffaf5;
    border:2px solid #ff7a00;
    border-radius:12px;
    overflow:hidden;
    box-sizing:border-box;
    box-shadow:0 2px 0 rgba(255,122,0,0.18);
  }

.kb-btn{
  width:100%;
  border:0;
  padding:14px;
  font-family:'Poppins', Arial, sans-serif;
  font-size:16px;
  font-weight:700;
  cursor:pointer;
  text-align:center;
  background:#ffd1a3; /* 👈 naranja pastel */
  color:#000; /* 👈 mejor contraste */
}

  .kb-content{
    display:none;
    background:#fffaf5;
    border-top:2px solid #ff7a00;
    padding:14px;
    line-height:1.5;
    text-align:left;
  }

  .kb-content.open{
    display:block;
  }

  .kb-content p{
    margin:8px 0;
  }

  .kb-content ul{
    margin:8px 0 0;
    padding-left:20px;
  }

  .kb-content li{
    margin-bottom:6px;
  }

  .kb-tag{
    display:inline-block;
    background:#ff7a00;
    color:#fff;
    font-size:13px;
    font-weight:700;
    padding:5px 10px;
    border-radius:999px;
    margin-bottom:8px;
  }
</style>

